{
  "expo": {
    "name": "QponAI",
    "slug": "qpon-ai",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "qponai",
    "userInterfaceStyle": "automatic",
    "jsEngine": "hermes",
    "newArchEnabled": true,
    "entryPoint": "./index.tsx",
    "experiments": {
      "tsconfigPaths": true,
      "typedRoutes": true,
      "typedRoots": true
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.yourcompany.qponai",
      "infoPlist": {
        "NSCameraUsageDescription": "Allow QponAI to access your camera to scan barcodes.",
        "NSPhotoLibraryUsageDescription": "Allow QponAI to access your photo library to upload images for barcode scanning."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#4CAF50"
      },
      "edgeToEdgeEnabled": true,
      "permissions": [
        "CAMERA",
        "READ_EXTERNAL_STORAGE",
        "WRITE_EXTERNAL_STORAGE"
      ],
      "package": "com.yourcompany.qponai"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff"
        }
      ],
      [
        "expo-barcode-scanner",
        {
          "cameraPermission": "Allow QponAI to access your camera to scan barcodes."
        }
      ]
    ]
  }
}
